<div class="stats-grid">
  <div class="stat-card"><span class="stat-value"><%= cuenta.displayName || cuenta.id %></span><span class="stat-label">Nombre</span></div>
  <div class="stat-card"><span class="stat-value"><%= cuenta.iban || '—' %></span><span class="stat-label">IBAN</span></div>
  <div class="stat-card"><span class="stat-value"><%= (cuenta.balancePz || 0).toLocaleString() %></span><span class="stat-label">Saldo (Pz)</span></div>
  <div class="stat-card"><span class="stat-value"><span class="badge badge-info"><%= cuenta.type %></span></span><span class="stat-label">Tipo</span></div>
</div>

<div style="background:var(--surface);border-radius:var(--radius);padding:24px;box-shadow:var(--shadow);margin-bottom:24px">
  <h3 style="font-size:16px;font-weight:700;margin-bottom:16px">📋 Datos de la Cuenta</h3>
  <table style="width:100%">
    <tr><td style="padding:8px 0;font-weight:600">ID</td><td class="text-mono"><%= cuenta.id %></td></tr>
    <tr><td style="padding:8px 0;font-weight:600">PlacetaID</td><td class="text-mono"><%= cuenta.placetaId || '—' %></td></tr>
    <tr><td style="padding:8px 0;font-weight:600">EIP</td><td class="text-mono"><%= cuenta.eip || '—' %></td></tr>
    <tr><td style="padding:8px 0;font-weight:600">Tipo</td><td><%= cuenta.type %></td></tr>
    <tr><td style="padding:8px 0;font-weight:600">Cuenta Padre</td><td class="text-mono"><%= cuenta.parentAccountId || '—' %></td></tr>
    <tr><td style="padding:8px 0;font-weight:600">Límite envío</td><td><%= cuenta.sendLimitPz || 'Sin límite' %> Pz</td></tr>
    <tr><td style="padding:8px 0;font-weight:600">Citizenship</td><td><%= cuenta.citizenshipTier || '—' %></td></tr>
    <tr><td style="padding:8px 0;font-weight:600">Compliance</td><td><span class="badge <%= cuenta.complianceStatus === 'Clear' ? 'badge-success' : 'badge-warning' %>"><%= cuenta.complianceStatus || 'Pending' %></span></td></tr>
    <tr><td style="padding:8px 0;font-weight:600">Creada</td><td><%= cuenta.createdAt ? new Date(cuenta.createdAt).toLocaleDateString() : '—' %></td></tr>
    <% if (cuenta.closedAt) { %><tr><td style="padding:8px 0;font-weight:600;color:var(--danger)">Cerrada</td><td><%= new Date(cuenta.closedAt).toLocaleDateString() %></td></tr><% } %>
  </table>
</div>

<!-- Guía de acciones según rol -->
<div class="info-card mb-16">
  <h4>👤 Tus Acciones Disponibles</h4>
  <p><strong>👁️ Ver:</strong> Datos completos de la cuenta, IBAN, saldo y estado de compliance.</p>
  <% if (esAdmin) { %>
  <p><strong>✏️ Modificar:</strong> Cambiar nombre, límites y configuración de la cuenta.</p>
  <p><strong>🔗 EIP:</strong> Vincular una empresa (EIP) como cotitular de la cuenta.</p>
  <p><strong>👥 Cotitular:</strong> Añadir o eliminar cotitulares.</p>
  <p><strong>🔒 Bloqueo:</strong> Bloquear o desbloquear la cuenta ante sospechas de fraude.</p>
  <% } else { %>
  <p style="color:var(--text-muted)">🔒 Acciones de administración no disponibles. Contacta con un administrador.</p>
  <% } %>
</div>

<% if (esAdmin) { %>
<div class="flex gap-8 flex-wrap">
  <button class="btn-icon" onclick="mostrarModificarCuenta('<%= cuenta.id %>','<%= (cuenta.displayName || cuenta.id).replace(/'/g,"\\'") %>',<%= cuenta.sendLimitPz || 0 %>)" title="Modificar cuenta">✏️</button>
  <button class="btn-icon" onclick="cambiarTipoCuenta('<%= cuenta.id %>','<%= cuenta.type || 'Personal' %>')" title="Cambiar tipo de cuenta">🏷️</button>
  <button class="btn-icon" onclick="mostrarVincularEIP('<%= cuenta.id %>')" title="Vincular EIP">🔗</button>
  <button class="btn-icon" onclick="mostrarAnadirCotitular('<%= cuenta.id %>','<%= (cuenta.displayName || cuenta.id).replace(/'/g,"\\'") %>')" title="Añadir cotitular">👥</button>
  <button class="btn-icon" onclick="mostrarQuitarCotitular('<%= cuenta.id %>')" title="Quitar cotitular">🚫</button>
  <% if (!cuenta.closedAt) { %>
  <button class="btn-icon" onclick="bloquearCuenta('<%= cuenta.id %>')" title="Bloquear cuenta" style="color:#d03131">🔒</button>
  <% } else { %>
  <button class="btn-icon" onclick="bloquearCuenta('<%= cuenta.id %>')" title="Desbloquear cuenta">🔓</button>
  <% } %>
</div>
<% } %>

<%- include('../parciales/documentos-ctx', { entidad: 'banco', refTipo: 'cuenta', refId: cuenta.id, refNombre: cuenta.displayName || cuenta.id }) %>

<script>
function mostrarModificarCuenta(id, nombre, limite) {
  const h = '<div style="margin-bottom:12px">' +
    '<p style="margin-bottom:12px;color:#666">Modificar datos de <strong>' + nombre + '</strong></p>' +
    '<label style="display:block;font-size:12px;font-weight:600;color:#666;margin-bottom:4px">Nombre:</label>' +
    '<input type="text" id="editNombre" class="form-input" value="' + (nombre || '') + '" style="width:100%;margin-bottom:12px">' +
    '<label style="display:block;font-size:12px;font-weight:600;color:#666;margin-bottom:4px">Límite de envío (Pz):</label>' +
    '<input type="number" id="editLimite" class="form-input" value="' + (limite || 0) + '" style="width:100%;margin-bottom:12px">' +
    '<button class="btn-primary" onclick="guardarCambiosCuenta(\'' + id + '\')">💾 Guardar Cambios</button>' +
    '</div>';
  mostrarModal('✏️ Modificar Cuenta', h);
}

function cambiarTipoCuenta(id, tipoActual) {
  mostrarModal('🏷️ Cambiar Tipo de Cuenta', `
    <p style="margin-bottom:12px">Cambiar tipo de <strong>${id}</strong>:</p>
    <p style="font-size:12px;color:#5c5566;margin-bottom:8px">Tipo actual: <span class="badge badge-purple">${tipoActual}</span></p>
    <select id="nuevoTipo" class="form-input" style="margin-bottom:12px">
      <option value="Personal" ${tipoActual==='Personal'?'selected':''}>👤 Personal</option>
      <option value="Business" ${tipoActual==='Business'?'selected':''}>🏢 Business (Empresa)</option>
      <option value="Savings" ${tipoActual==='Savings'?'selected':''}>💰 Savings (Ahorro)</option>
      <option value="Current" ${tipoActual==='Current'?'selected':''}>💳 Current (Corriente)</option>
      <option value="Child" ${tipoActual==='Child'?'selected':''}>🧒 Child (Infantil)</option>
      <option value="Shared" ${tipoActual==='Shared'?'selected':''}>👥 Shared (Compartida)</option>
      <option value="Joint" ${tipoActual==='Joint'?'selected':''}>🤝 Joint (Conjunta)</option>
    </select>
    <p style="font-size:11px;color:#999;margin-bottom:12px">💡 El cambio de tipo afecta a límites de capital (Art. 4.1), escala IRM (Art. 4.10) e IGF (Art. 4.12-4.16).</p>
    <button class="btn btn-primary" onclick='ejecutarCambioTipo("${id}")'>💾 Cambiar tipo</button>
  `);
}

async function ejecutarCambioTipo(id) {
  const tipo = document.getElementById('nuevoTipo')?.value;
  if (!tipo) return mostrarToast('Selecciona un tipo', 'error');
  try {
    const r = await apiFetch('/banco/api/cuentas/modificar', {
      method: 'POST', body: JSON.stringify({ accountId: id, type: tipo })
    });
    if (r.success) { mostrarToast('🏷️ Tipo cambiado a ' + tipo, 'success'); setTimeout(() => location.reload(), 800); }
    else mostrarToast(r.error||'Error', 'error');
  } catch(e) { mostrarToast('⚠️ Simulado: tipo cambiado', 'warning'); setTimeout(() => location.reload(), 600); }
}

function mostrarVincularEIP(id) {
  const h = '<div style="margin-bottom:12px">' +
    '<p style="margin-bottom:12px;color:#666">Vincula una empresa (EIP) como cotitular de la cuenta.</p>' +
    '<input type="text" id="eipInput" class="form-input" placeholder="EIP de la empresa (ej: EIP-A3F7C2)" style="width:100%;margin-bottom:12px">' +
    '<button class="btn-primary" onclick="vincularEIP(\'' + id + '\')">🔗 Vincular</button>' +
    '</div>';
  mostrarModal('🔗 Vincular EIP', h);
}

function mostrarAnadirCotitular(id, nombre) {
  const h = '<div style="margin-bottom:12px">' +
    '<p style="margin-bottom:12px;color:#666">Añade un cotitular a la cuenta <strong>' + nombre + '</strong></p>' +
    '<input type="text" id="cotitularDip" class="form-input" placeholder="DIP del cotitular" style="width:100%;margin-bottom:12px">' +
    '<button class="btn-primary" onclick="anadirCotitular(\'' + id + '\')">➕ Añadir</button>' +
    '</div>';
  mostrarModal('👥 Añadir Cotitular', h);
}

function mostrarQuitarCotitular(id) {
  const h = '<div style="margin-bottom:12px">' +
    '<p style="margin-bottom:12px;color:#666">Introduce el DIP del cotitular a eliminar:</p>' +
    '<input type="text" id="quitarCotitularDip" class="form-input" placeholder="DIP del cotitular" style="width:100%;margin-bottom:12px">' +
    '<button class="btn-danger" onclick="quitarCotitular(\'' + id + '\')">🚫 Quitar</button>' +
    '</div>';
  mostrarModal('🚫 Quitar Cotitular', h);
}

async function guardarCambiosCuenta(id) {
  const nombre = document.getElementById('editNombre')?.value;
  const limite = document.getElementById('editLimite')?.value;
  try {
    await apiFetch('/api/banco/action', {
      method: 'POST',
      body: JSON.stringify({ action: 'modificar-cuenta', accountId: id, displayName: nombre, sendLimitPz: parseInt(limite) })
    });
    mostrarToast('✅ Cambios guardados', 'success');
    setTimeout(() => location.reload(), 1000);
  } catch { mostrarToast('⚠️ Simulado: cambios guardados', 'warning'); location.reload(); }
}

async function vincularEIP(id) {
  const eip = document.getElementById('eipInput')?.value;
  if (!eip) return mostrarToast('Introduce un EIP', 'error');
  try {
    await apiFetch('/api/banco/action', { method: 'POST', body: JSON.stringify({ action: 'vincular-eip', accountId: id, eip }) });
    mostrarToast('🔗 EIP vinculado', 'success');
    setTimeout(() => location.reload(), 1000);
  } catch { mostrarToast('⚠️ Simulado: EIP vinculado', 'warning'); location.reload(); }
}

async function anadirCotitular(id) {
  const dip = document.getElementById('cotitularDip')?.value;
  if (!dip) return mostrarToast('Introduce un DIP', 'error');
  try {
    await apiFetch('/api/banco/action', { method: 'POST', body: JSON.stringify({ action: 'anadir-cotitular', accountId: id, dip }) });
    mostrarToast('👥 Cotitular añadido', 'success');
    setTimeout(() => location.reload(), 1000);
  } catch { mostrarToast('⚠️ Simulado: cotitular añadido', 'warning'); location.reload(); }
}

async function quitarCotitular(id) {
  const dip = document.getElementById('quitarCotitularDip')?.value;
  if (!dip) return mostrarToast('Introduce un DIP', 'error');
  if (!confirm('¿Quitar a ' + dip + ' como cotitular de esta cuenta?')) return;
  try {
    await apiFetch('/api/banco/action', { method: 'POST', body: JSON.stringify({ action: 'quitar-cotitular', accountId: id, dip }) });
    mostrarToast('🚫 Cotitular eliminado', 'success');
    setTimeout(() => location.reload(), 1000);
  } catch { mostrarToast('⚠️ Simulado: cotitular eliminado', 'warning'); location.reload(); }
}

async function bloquearCuenta(id) {
  if (!confirm('¿Bloquear/desbloquear esta cuenta?')) return;
  try {
    await apiFetch('/api/banco/action', { method: 'POST', body: JSON.stringify({ action: 'toggle-bloqueo', accountId: id }) });
    mostrarToast('✅ Estado cambiado', 'success');
    setTimeout(() => location.reload(), 1000);
  } catch { mostrarToast('⚠️ Simulado', 'warning'); location.reload(); }
}
</script>
