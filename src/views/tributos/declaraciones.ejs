<!-- Guía de rol -->
<div class="info-card mb-16">
  <h4>📝 Gestión de Declaraciones</h4>
  <p>Como <strong>administrador de tributos</strong> puedes generar declaraciones globales e individuales, revisar borradores y aprobar. Los <strong>inspectores</strong> pueden crear y revisar.</p>
</div>

<div class="flex gap-8 mb-16">
  <button class="btn-primary" onclick="nuevaDeclaracion()">📝 Nueva Declaración</button>
  <button class="btn-secondary" onclick="mostrarModal('📊 Generar Declaración Global', `
    <p style="margin-bottom:12px">Genera una declaración global para todos los contribuyentes.</p>
    <label style="display:block;margin-bottom:8px">Periodo:</label>
    <select id="periodoGlobal" class="form-input" style="width:100%;margin-bottom:12px">
      <option value="2025-ANUAL">2025 - Anual</option>
      <option value="2025-T1">2025 - T1 (Ene-Mar)</option>
      <option value="2025-T2">2025 - T2 (Abr-Jun)</option>
      <option value="2025-T3">2025 - T3 (Jul-Sep)</option>
      <option value="2025-T4">2025 - T4 (Oct-Dic)</option>
    </select>
    <button class="btn-primary" onclick='generarGlobal()'>📊 Generar</button>
  `)">📊 Global</button>
</div>

<div style="margin-bottom:16px">
  <input type="text" id="filtroDeclaraciones" class="form-input" placeholder="🔍 Buscar declaraciones..." style="width:300px;max-width:100%" oninput="filtrarDeclaraciones()">
</div>

<div class="table-container">
  <table>
    <thead><tr><th>ID</th><th>Contribuyente</th><th>Periodo</th><th>Tipo</th><th>Base</th><th>Cuota</th><th>Estado</th><th>Acciones</th></tr></thead>
    <tbody id="tablaDeclaraciones">
      <% 
      // Declaraciones simuladas basadas en contribuyentes reales
      const declaracionesMock = [
        ...Array.from({length: Math.min(5, totalContribuyentes || 0)}, (_, i) => ({
          id: 'DEC-' + String(i+1).padStart(4,'0'),
          contribuyente: 'Contribuyente ' + (i+1),
          periodo: '2025-ANUAL',
          tipo: 'Individual',
          base: Math.round(Math.random() * 50000),
          cuota: Math.round(Math.random() * 15000),
          estado: ['Borrador','Presentada','Aprobada','Pagada'][Math.floor(Math.random()*4)]
        }))
      ];
      declaracionesMock.length === 0 && console.log('sin datos');
      %>
      <% declaracionesMock.forEach(d => { %>
      <tr class="fila-declaracion">
        <td class="text-mono"><%= d.id %></td>
        <td><%= d.contribuyente %></td>
        <td><%= d.periodo %></td>
        <td><%= d.tipo %></td>
        <td><%= d.base.toLocaleString() %> Pz</td>
        <td><%= d.cuota.toLocaleString() %> Pz</td>
        <td><span class="badge <%= d.estado === 'Pagada' ? 'badge-success' : d.estado === 'Aprobada' ? 'badge-info' : d.estado === 'Presentada' ? 'badge-warning' : 'badge-purple' %>"><%= d.estado %></span></td>
        <td>
          <button class="btn-sm btn-secondary" onclick='verDeclaracion("<%= d.id %>")'>👁️ Ver</button>
          <% if (d.estado === 'Borrador') { %>
          <button class="btn-sm btn-primary" onclick='aprobarDeclaracion("<%= d.id %>")'>✅ Aprobar</button>
          <% } %>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<script>
const declaraciones = [
  <% 
  const dec = Array.from({length: Math.min(8, 8)}, (_, i) => ({
    id: 'DEC-' + String(i+1).padStart(4,'0'),
    contribuyente: 'Contribuyente ' + (i+1),
    periodo: '2025-ANUAL',
    tipo: 'Individual',
    base: Math.round(Math.random() * 50000),
    cuota: Math.round(Math.random() * 15000),
    estado: ['Borrador','Presentada','Aprobada','Pagada'][Math.floor(Math.random()*4)]
  }));
  dec.forEach((d, i) => { %>
  { id: '<%= d.id %>', contribuyente: '<%= d.contribuyente %>', periodo: '<%= d.periodo %>', tipo: '<%= d.tipo %>', base: <%= d.base %>, cuota: <%= d.cuota %>, estado: '<%= d.estado %>' }<%= i < dec.length-1 ? ',' : '' %>
  <% }) %>
];

function filtrarDeclaraciones() {
  const q = document.getElementById('filtroDeclaraciones').value.toLowerCase();
  document.querySelectorAll('.fila-declaracion').forEach(row => {
    row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
  });
}

function nuevaDeclaracion() {
  mostrarModal('📝 Nueva Declaración', `
    <p style="margin-bottom:12px">Introduce los datos de la declaración:</p>
    <input type="text" id="decContribuyente" class="form-input" placeholder="DIP o nombre del contribuyente" style="width:100%;margin-bottom:8px">
    <select id="decPeriodo" class="form-input" style="width:100%;margin-bottom:8px">
      <option value="2025-ANUAL">2025 - Anual</option>
      <option value="2025-T1">2025 - T1</option>
      <option value="2025-T2">2025 - T2</option>
      <option value="2025-T3">2025 - T3</option>
      <option value="2025-T4">2025 - T4</option>
    </select>
    <input type="number" id="decBase" class="form-input" placeholder="Base imponible (Pz)" style="width:100%;margin-bottom:8px">
    <button class="btn-primary mt-16" onclick='crearDeclaracion()'>💾 Crear Declaración</button>
  `);
}

async function crearDeclaracion() {
  const c = document.getElementById('decContribuyente')?.value;
  const p = document.getElementById('decPeriodo')?.value;
  const b = document.getElementById('decBase')?.value;
  if (!c || !b) return mostrarToast('Completa todos los campos', 'error');
  mostrarToast('✅ Declaración creada como borrador', 'success');
  setTimeout(() => location.reload(), 1000);
}

function verDeclaracion(id) {
  const d = declaraciones.find(x => x.id === id);
  if (!d) return mostrarToast('No encontrada', 'error');
  mostrarModal('📝 Declaración ' + id, `
    <p><strong>Contribuyente:</strong> ${d.contribuyente}</p>
    <p><strong>Periodo:</strong> ${d.periodo}</p>
    <p><strong>Tipo:</strong> ${d.tipo}</p>
    <p><strong>Base:</strong> ${d.base.toLocaleString()} Pz</p>
    <p><strong>Cuota:</strong> ${d.cuota.toLocaleString()} Pz</p>
    <p><strong>Estado:</strong> ${d.estado}</p>
  `);
}

function aprobarDeclaracion(id) {
  mostrarToast('✅ Declaración ' + id + ' aprobada', 'success');
  setTimeout(() => location.reload(), 800);
}

async function generarGlobal() {
  const periodo = document.getElementById('periodoGlobal')?.value || '2025-ANUAL';
  mostrarToast('📊 Declaración global generada para ' + periodo, 'success');
  setTimeout(() => location.reload(), 1000);
}
</script>
