<div class="stats-grid">
  <div class="stat-card"><span class="stat-value"><%= total %></span><span class="stat-label">Registros PlacetaID</span></div>
</div>
<div class="table-container">
  <table>
    <thead><tr><th>DIP</th><th>Nombre</th><th>Email</th><th>Verificado</th><th>Acciones</th></tr></thead>
    <tbody>
      <% (registros || []).slice(0, 50).forEach(r => { %>
      <tr>
        <td class="text-mono"><%= r.dip %></td>
        <td><%= r.nombre || '—' %></td>
        <td><%= r.email || '—' %></td>
        <td><span class="badge <%= r.totpVerificado ? 'badge-success' : 'badge-warning' %>"><%= r.totpVerificado ? 'Sí' : 'No' %></span></td>
        <td><button class="btn-sm btn-secondary" onclick='verRegistroPlacetaid("<%= r.dip %>")'>👁️ Ver</button></td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<div class="info-card mt-16">
  <h4>🔑 PlacetaID</h4>
  <p>Lista de usuarios registrados en PlacetaID. Verifica el estado TOTP de cada registro.</p>
</div>

<script>
function verRegistroPlacetaid(dip) {
  mostrarModal('🔑 Registro: ' + dip, `
    <p><strong>DIP:</strong> ${dip}</p>
    <p><strong>Nombre:</strong> Usuario</p>
    <p><strong>Email:</strong> usuario@ejemplo.com</p>
    <p><strong>TOTP:</strong> Verificado</p>
    <p><strong>Fecha registro:</strong> 2024-01-15</p>
    <div class="actions">
      <button class="btn-secondary" onclick="mostrarToast('📨 Notificación enviada','success')">📨 Notificar</button>
    </div>
  `);
}
</script>
