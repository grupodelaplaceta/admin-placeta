<!-- Calculadora rápida -->
<h4 class="mb-16">🧮 Calculadora Rápida de Impuestos</h4>
<div class="info-card">
  <div class="grid-3" style="gap:8px">
    <div><label style="font-size:12px;display:block;margin-bottom:4px">Patrimonio medio (Pz):</label><input type="number" id="calcPatrimonio" class="form-input" value="10000" style="width:100%"></div>
    <div><label style="font-size:12px;display:block;margin-bottom:4px">Tipo:</label>
      <select id="calcTipo" class="form-input" style="width:100%">
        <option value="personal">Personal</option>
        <option value="empresa">Empresa</option>
      </select>
    </div>
    <div><label style="font-size:12px;display:block;margin-bottom:4px">IA (índice acumulación):</label>
      <input type="number" id="calcIA" class="form-input" value="0.05" step="0.01" style="width:100%">
    </div>
  </div>
  <button class="btn-primary mt-16" onclick="calcularImpuestos()">🧮 Calcular</button>
  <div id="calcResultados" class="mt-16" style="font-size:13px"></div>
</div>

<hr style="margin:24px 0;border-color:rgba(139,92,246,0.15)">

<h4 class="mb-16">⚖️ Base Legal Completa</h4>
<div class="info-card" style="font-size:13px;line-height:1.8">
  <ul>
    <li><strong>Art. 4.1</strong> — Límites de capital. Personal/Savings/Current: 500.000 Pz. Business: 10.000.000 Pz. Child: 5.000 Pz.</li>
    <li><strong>Art. 4.2</strong> — Sanciones por descubierto. Día 6+: 25.000 Pz. Día 30+: 125.000 Pz.</li>
    <li><strong>Art. 4.3</strong> — Tasa de transferencia. Máximo 12%.</li>
    <li><strong>Art. 4.4</strong> — IVA general del 12% sobre base imponible.</li>
    <li><strong>Art. 4.5</strong> — Cotizaciones laborales progresivas (7,5%–17,5%).</li>
    <li><strong>Art. 4.7</strong> — SMI: 150 Pz/mes. Salario Máximo: 1.750 Pz/mes.</li>
    <li><strong>Art. 4.8</strong> — IRM mensual sobre patrimonio medio del periodo vencido.</li>
    <li><strong>Art. 4.9</strong> — IA = (Ingresos medios - Pagos medios) / Patrimonio medio.</li>
    <li><strong>Art. 4.10</strong> — Escala IRM progresiva por tipo de cuenta.</li>
    <li><strong>Art. 4.11</strong> — Liquidación mensual. Cargo día 5 del mes siguiente (Art. 4.11 bis).</li>
    <li><strong>Art. 4.12</strong> — IGF grava patrimonio > 5.000 Pz.</li>
    <li><strong>Art. 4.13</strong> — IGF personal: 10% y 30%.</li>
    <li><strong>Art. 4.14</strong> — IGF empresa: 5%, 35% y 85%.</li>
    <li><strong>Art. 4.15</strong> — Empresas &lt; 20.000 Pz: IGF exento.</li>
    <li><strong>Art. 4.16</strong> — Exención primeros 5.000 Pz para todos.</li>
    <li><strong>Art. 4.17</strong> — IVA 12% en facturas.</li>
    <li><strong>Art. 5 (Junior)</strong> — Capitalia paga impuestos. Bono 750 Pz.</li>
    <li><strong>Art. 7</strong> — Tipos de cuenta por edad.</li>
    <li><strong>Art. 15</strong> — Sueldos públicos.</li>
  </ul>
</div>

<script>
async function calcularImpuestos() {
  const p = parseFloat(document.getElementById('calcPatrimonio')?.value) || 0;
  const t = document.getElementById('calcTipo')?.value;
  const ia = parseFloat(document.getElementById('calcIA')?.value) || 0;
  let irmTipo = 0;
  if (t === 'empresa') {
    if (ia <= 0) irmTipo = 0; else if (ia <= 0.05) irmTipo = 0.01; else if (ia <= 0.15) irmTipo = 0.03; else if (ia <= 0.30) irmTipo = 0.06; else irmTipo = 0.09;
  } else {
    if (ia <= 0) irmTipo = 0; else if (ia <= 0.05) irmTipo = 0.005; else if (ia <= 0.15) irmTipo = 0.015; else if (ia <= 0.30) irmTipo = 0.03; else irmTipo = 0.05;
  }
  const cuotaIRM = p * irmTipo;
  let igfTotal = 0, igfTramos = [];
  if (p > 5000) {
    const b1 = Math.min(p - 5000, 15000);
    const c1 = b1 * (t === 'empresa' ? 0.05 : 0.10);
    igfTramos.push({ label: '5.001-20.000', base: b1, cuota: c1 }); igfTotal += c1;
    if (p > 20000) {
      const b2 = Math.min(p - 20000, 480000);
      const c2 = b2 * (t === 'empresa' ? 0.35 : 0.30);
      igfTramos.push({ label: '20.001-500.000', base: b2, cuota: c2 }); igfTotal += c2;
      if (t === 'empresa' && p > 500000) {
        const b3 = p - 500000; const c3 = b3 * 0.85;
        igfTramos.push({ label: '>500.000', base: b3, cuota: c3 }); igfTotal += c3;
      }
    }
  }
  document.getElementById('calcResultados').innerHTML = `
    <div class="grid-3" style="gap:8px">
      <div style="background:#f5f3f7;padding:12px;border-radius:8px;text-align:center">
        <p style="font-size:11px;color:#5c5566">IRM (${(irmTipo*100).toFixed(2)}%)</p>
        <p style="font-size:20px;font-weight:700;color:#3f00d8">${cuotaIRM.toFixed(2)} Pz</p>
      </div>
      <div style="background:#f5f3f7;padding:12px;border-radius:8px;text-align:center">
        <p style="font-size:11px;color:#5c5566">IGF</p>
        <p style="font-size:20px;font-weight:700;color:#3f00d8">${igfTotal.toFixed(2)} Pz</p>
        <p style="font-size:10px;color:#5c5566">${igfTramos.length} tramos</p>
      </div>
      <div style="background:#efe9fb;padding:12px;border-radius:8px;text-align:center">
        <p style="font-size:11px;color:#5c5566">TOTAL</p>
        <p style="font-size:24px;font-weight:700;color:#1c005f">${(cuotaIRM+igfTotal).toFixed(2)} Pz</p>
      </div>
    </div>
    <p style="font-size:10px;color:#9a8aaa;margin-top:8px">Basado en Arts. 4.8-4.16 del Código Normativo Interno GDLP</p>
  `;
}
</script>
