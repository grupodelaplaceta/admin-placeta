<div class="stats-grid">
  <div class="stat-card"><span class="stat-value"><%= totalCiudadanos %></span><span class="stat-label">Ciudadanos</span></div>
  <div class="stat-card"><span class="stat-value"><%= placetaidStats?.total || '—' %></span><span class="stat-label">Registros PlacetaID</span></div>
</div>

<div class="flex gap-8" style="flex-wrap:wrap">
  <a href="/junta/ciudadanos" class="btn-primary">👥 Ciudadanos</a>
  <a href="/junta/placetaid" class="btn-secondary">🔑 PlacetaID</a>
  <a href="/junta/reclamaciones" class="btn-secondary">📨 Reclamaciones</a>
  <a href="/junta/reuniones" class="btn-secondary">🤝 Reuniones</a>
  <a href="/junta/votaciones" class="btn-secondary">🗳️ Votaciones</a>
  <a href="/junta/cargos" class="btn-secondary">👤 Cargos</a>
  <a href="/junta/recursos" class="btn-secondary">📦 Recursos</a>
  <a href="/junta/junior" class="btn-secondary">🧒 Junior</a>
</div>

<div style="background:var(--surface);border-radius:var(--radius);padding:20px;box-shadow:var(--shadow);margin-top:24px">
  <p style="font-size:13px;color:var(--text-light)">
    <% if (esPresidente) { %>✅ Acceso como <strong>Presidente/Vicepresidente</strong> — todas las secciones disponibles.<% } %>
    <% if (esSecretario) { %>📋 Acceso como <strong>Secretario</strong> — reclamaciones, reuniones y recursos.<% } %>
  </p>
</div>
