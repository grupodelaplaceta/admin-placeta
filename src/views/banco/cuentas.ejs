<!-- Filtros y acciones -->
<div class="flex gap-8 mb-16 flex-wrap items-center">
  <div class="flex gap-8" style="flex:1">
    <input type="text" id="searchInput" placeholder="🔍 Buscar cuenta..." class="form-input" style="width:220px" value="<%= query.busqueda || '' %>">
    <button class="btn btn-secondary" data-search-btn>🔍</button>
  </div>
  <select id="filtroTipo" class="form-input" style="width:140px" onchange="filtrarCuentas()">
    <option value="">📋 Todos los tipos</option>
    <option value="Personal" <%= query.tipo === 'Personal' ? 'selected' : '' %>>👤 Personal</option>
    <option value="Business" <%= query.tipo === 'Business' ? 'selected' : '' %>>🏢 Business</option>
    <option value="Savings" <%= query.tipo === 'Savings' ? 'selected' : '' %>>💰 Savings</option>
    <option value="Current" <%= query.tipo === 'Current' ? 'selected' : '' %>>💳 Current</option>
    <option value="Child" <%= query.tipo === 'Child' ? 'selected' : '' %>>🧒 Child</option>
    <option value="Shared" <%= query.tipo === 'Shared' ? 'selected' : '' %>>👥 Shared</option>
    <option value="Joint" <%= query.tipo === 'Joint' ? 'selected' : '' %>>🤝 Joint</option>
  </select>
  <select id="filtroEstado" class="form-input" style="width:130px" onchange="filtrarCuentas()">
    <option value="">📊 Todos</option>
    <option value="activas" <%= query.estado === 'activas' ? 'selected' : '' %>>🟢 Activas</option>
    <option value="cerradas" <%= query.estado === 'cerradas' ? 'selected' : '' %>>🔴 Cerradas</option>
  </select>
  <a href="/banco/cuentas/nueva/gestor" class="btn btn-primary">➕ Nueva Cuenta</a>
</div>

<div class="table-container">
  <table>
    <thead>
      <tr>
        <th style="width:50px">ID</th>
        <th>👤 Nombre</th>
        <th style="width:90px">🏷️ Tipo</th>
        <th style="width:130px">🔢 IBAN</th>
        <th style="width:90px">💰 Saldo</th>
        <th style="width:80px">🔗 EIP</th>
        <th style="width:80px">📊 Estado</th>
        <th style="width:140px">⚡ Acciones</th>
      </tr>
    </thead>
    <tbody>
      <% (cuentas || []).forEach(c => { %>
      <tr>
        <td class="text-mono" style="font-size:10px"><%= c.id?.slice(0,8) %></td>
        <td><a href="/banco/cuentas/<%= c.id %>" style="font-weight:600;font-size:13px"><%= c.displayName || '—' %></a></td>
        <td><span class="badge <%= 
          c.type === 'Business' ? 'badge-purple' :
          c.type === 'Child' ? 'badge-info' :
          c.type === 'Savings' ? 'badge-success' :
          c.type === 'Current' ? 'badge-warning' :
          c.type === 'Shared' || c.type === 'Joint' ? 'badge-gold' :
          'badge-outline' %>"><%= c.type || '—' %></span></td>
        <td class="text-mono" style="font-size:10px"><%= c.iban || '—' %></td>
        <td><strong style="color:var(--p)"><%= (c.balancePz || 0).toLocaleString() %></strong> <span style="font-size:10px;color:#888">Pz</span></td>
        <td class="text-mono" style="font-size:10px"><%= c.eip || '—' %></td>
        <td>
          <span class="badge badge-dot <%= c.closedAt ? 'closed' : 'active' %> <%= c.closedAt ? 'badge-danger' : 'badge-success' %>">
            <%= c.closedAt ? '🔒 Cerrada' : '🟢 Activa' %>
          </span>
        </td>
        <td>
          <div class="flex gap-4" style="flex-wrap:nowrap">
            <a href="/banco/cuentas/<%= c.id %>" class="btn-icon" title="Ver detalle">👁️</a>
            <button class="btn-icon" onclick="event.stopPropagation();cambiarTipoCuenta('<%= c.id %>','<%= c.type || 'Personal' %>')" title="Cambiar tipo">🏷️</button>
            <button class="btn-icon" onclick="event.stopPropagation();verDocsDe('cuenta','<%= c.id %>','banco','<%= (c.displayName || c.id).slice(0,20).replace(/'/g,"\\'") %>')" title="Documentos">📎</button>
          </div>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>
<p style="font-size:12px;color:#999;margin-top:8px">Total: <strong><%= total %></strong> cuentas bancarias</p>

<script>
function filtrarCuentas() {
  const tipo = document.getElementById('filtroTipo')?.value || '';
  const estado = document.getElementById('filtroEstado')?.value || '';
  const busqueda = document.getElementById('searchInput')?.value || '';
  const params = new URLSearchParams();
  if (tipo) params.set('tipo', tipo);
  if (estado) params.set('estado', estado);
  if (busqueda) params.set('busqueda', busqueda);
  window.location = '/banco/cuentas?' + params.toString();
}

async function cambiarTipoCuenta(id, tipoActual) {
  mostrarModal('🏷️ Cambiar Tipo de Cuenta', `
    <p style="margin-bottom:12px">Cambiar tipo de <strong>${id}</strong>:</p>
    <label style="display:block;margin-bottom:4px;font-size:12px">Tipo actual: <span class="badge badge-purple">${tipoActual}</span></label>
    <select id="nuevoTipo" class="form-input" style="margin-bottom:12px">
      <option value="Personal" ${tipoActual==='Personal'?'selected':''}>👤 Personal</option>
      <option value="Business" ${tipoActual==='Business'?'selected':''}>🏢 Business</option>
      <option value="Savings" ${tipoActual==='Savings'?'selected':''}>💰 Savings</option>
      <option value="Current" ${tipoActual==='Current'?'selected':''}>💳 Current</option>
      <option value="Child" ${tipoActual==='Child'?'selected':''}>🧒 Child</option>
      <option value="Shared" ${tipoActual==='Shared'?'selected':''}>👥 Shared</option>
      <option value="Joint" ${tipoActual==='Joint'?'selected':''}>🤝 Joint</option>
    </select>
    <button class="btn btn-primary" onclick='ejecutarCambioTipo("${id}")'>💾 Cambiar tipo</button>
  `);
}

async function ejecutarCambioTipo(id) {
  const tipo = document.getElementById('nuevoTipo')?.value;
  if (!tipo) return mostrarToast('Selecciona un tipo', 'error');
  try {
    const r = await apiFetch('/banco/api/cuentas/modificar', {
      method: 'POST', body: JSON.stringify({ accountId: id, type: tipo })
    });
    if (r.success) { mostrarToast('🏷️ Tipo cambiado a ' + tipo, 'success'); setTimeout(() => location.reload(), 800); }
    else mostrarToast(r.error||'Error', 'error');
  } catch(e) { mostrarToast('⚠️ Simulado: tipo cambiado', 'warning'); setTimeout(() => location.reload(), 600); }
}
</script>
