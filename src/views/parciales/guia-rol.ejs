<%# Guía de Rol - Muestra al usuario qué puede hacer según sus permisos %>
<% 
const guiaEntidad = {
  banco: {
    icono: '🏦',
    nombre: 'Banco de La Placeta',
    roles: [
      { rol: 'admin', label: 'Administrador', acciones: 'Ver, crear, modificar y bloquear cuentas. Gestionar tarjetas, nóminas, trabajadores y control de cumplimiento.' },
      { rol: 'gestor', label: 'Gestor de Cuentas', acciones: 'Ver cuentas, crear nuevas, modificar datos básicos y ver operaciones.' }
    ]
  },
  tributos: {
    icono: '📊',
    nombre: 'Tributos de La Placeta',
    roles: [
      { rol: 'admin', label: 'Administrador', acciones: 'Ver contribuyentes, crear/aprobar declaraciones, gestionar regímenes e incidencias. Inspección automática.' },
      { rol: 'inspector', label: 'Inspector', acciones: 'Ver contribuyentes, inspección automática, crear declaraciones y gestionar incidencias.' }
    ]
  },
  junta: {
    icono: '⚖️',
    nombre: 'Junta de La Placeta',
    roles: [
      { rol: 'presidente', label: 'Presidente', acciones: 'Acceso completo: ciudadanos, PlacetaID, reclamaciones, reuniones, votaciones, cargos, departamentos, recursos y junior.' },
      { rol: 'vicepresidente', label: 'Vicepresidente', acciones: 'Ciudadanos, PlacetaID, reclamaciones, reuniones, recursos y junior.' },
      { rol: 'secretario', label: 'Secretario', acciones: 'Reclamaciones, reuniones y recursos digitales.' },
      { rol: 'cargo_autorizado', label: 'Cargo Autorizado', acciones: 'Reuniones y recursos digitales.' }
    ]
  },
  administracion: {
    icono: '📋',
    nombre: 'Administración de La Placeta',
    roles: [
      { rol: 'presidente', label: 'Presidente', acciones: 'Trámites, ciudadanos, tributos (básico), banco (básico), actas, votaciones, PlacetaID completo y junior.' },
      { rol: 'vicepresidente', label: 'Vicepresidente', acciones: 'Trámites, ciudadanos, actas e inspección de votaciones.' },
      { rol: 'funcionario', label: 'Funcionario', acciones: 'Trámites, ciudadanos, actas y PlacetaID completo.' }
    ]
  }
};

const entidad = guiaEntidad[entidad_actual];
%>

<% if (entidad && roles && roles.length > 0) { %>
<div class="info-card mb-16">
  <div style="display:flex;align-items:center;gap:12px;margin-bottom:12px">
    <span style="font-size:24px"><%= entidad.icono %></span>
    <div>
      <h4 style="margin:0">👤 Tu Rol en <%= entidad.nombre %></h4>
    </div>
  </div>
  <% 
  // Encontrar qué roles del usuario aplican a esta entidad (SIN DUPLICADOS)
  const rolesVistos = {};
  const rolesAplicables = roles.filter(r => {
    const entRoles = Object.keys(guiaEntidad[entidad_actual]?.roles?.reduce((acc, r2) => { acc[r2.rol] = true; return acc; }, {}) || {});
    const match = entRoles.find(er => r.includes(er) || r.includes(entidad_actual + '_' + er));
    if (match && !rolesVistos[match]) { rolesVistos[match] = true; return true; }
    return false;
  });
  %>
  <% if (rolesAplicables.length > 0) { %>
    <% rolesAplicables.forEach(rol => { %>
      <%
      const guiaRol = entidad.roles.find(r => rol.includes(r.rol) || rol.includes(entidad_actual + '_' + r.rol));
      %>
      <% if (guiaRol) { %>
      <div style="padding:8px 12px;margin-bottom:4px;border-radius:6px;background:#f0eeff">
        <strong style="color:var(--p)"><%= guiaRol.label %></strong>
        <p style="font-size:12px;color:var(--tm);margin-top:2px"><%= guiaRol.acciones %></p>
      </div>
      <% } %>
    <% }) %>
  <% } else { %>
  <div style="padding:8px 12px;border-radius:6px;background:#f0eeff">
    <p style="font-size:12px;color:var(--tm)">🔒 No tienes roles específicos asignados en esta entidad. Contacta con un administrador.</p>
  </div>
  <% } %>
  <p style="font-size:11px;color:var(--l);margin-top:8px">💡 Usa el menú lateral para navegar entre las secciones disponibles según tu rol.</p>
</div>
<% } %>
