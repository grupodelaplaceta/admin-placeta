<div class="stats-grid">
  <div class="stat-card"><span class="stat-value"><%= total %></span><span class="stat-label">Registros PlacetaID</span></div>
</div>
<div class="table-container">
  <table>
    <thead><tr><th>DIP</th><th>Nombre</th><th>Email</th><th>Estado</th><th>Acciones</th></tr></thead>
    <tbody>
      <% (registros || []).slice(0, 50).forEach(r => { %>
      <tr><td class="text-mono"><%= r.dip %></td><td><%= r.nombre || '—' %></td><td><%= r.email || '—' %></td><td><span class="badge <%= r.bloqueado ? 'badge-danger' : 'badge-success' %>"><%= r.bloqueado ? 'Bloqueado' : 'Activo' %></span></td>
      <td>
        <button class="btn-sm btn-primary" onclick='desbloquearPlacetaid("<%= r.dip %>")'>✅ Desbloquear</button>
      </td></tr>
      <% }) %>
    </tbody>
  </table>
</div>

<div class="info-card mt-16">
  <h4>🔑 Acciones de PlacetaID</h4>
  <p>Como administrador puedes desbloquear usuarios bloqueados. Usa el botón <strong>Desbloquear</strong> en cada fila.</p>
</div>

<script>
async function desbloquearPlacetaid(dip) {
  try {
    const result = await apiFetch('/api/placetaid/desbloquear/' + dip, { method: 'POST' });
    if (result.success) {
      mostrarToast('✅ Usuario ' + dip + ' desbloqueado', 'success');
      setTimeout(() => location.reload(), 1000);
    } else {
      mostrarToast('⚠️ No se pudo desbloquear', 'error');
    }
  } catch {
    mostrarToast('⚠️ Simulado: usuario desbloqueado', 'warning');
    setTimeout(() => location.reload(), 1000);
  }
}
</script>
