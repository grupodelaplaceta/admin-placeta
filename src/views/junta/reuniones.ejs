async function crearVotacionLibre(cerrar) {
  const t = document.getElementById('votTituloLibre')?.value;
  if (!t) return mostrarToast('Introduce una propuesta', 'error');
  try {
    const res = await apiFetch('/junta/api/votaciones', {
      method:'POST', body: JSON.stringify({
        titulo: t, grupo: document.getElementById('votGrupoLibre')?.value,
        quorum: parseInt(document.getElementById('votQuorumLibre')?.value) || 50,
        aFavor: parseInt(document.getElementById('votFLibre')?.value) || 0,
        enContra: parseInt(document.getElementById('votCLibre')?.value) || 0,
        abstenciones: parseInt(document.getElementById('votALibre')?.value) || 0,
        cerrar
      })
    });
    if (res.success) { mostrarToast('✅ Votación ' + (cerrar ? 'cerrada' : 'creada'), 'success'); setTimeout(() => location.reload(), 800); }
    else mostrarToast(res.error||'Error', 'error');
  } catch(e) { mostrarToast('Error de red', 'error'); }
}

// ═════════════════════════════════════════════════════════════════════════
// 8. EDITAR REUNIÓN
// ═════════════════════════════════════════════════════════════════════════
function editarReunion(id) {
  const r = reuniones.find(x => x.id === id);
  if (!r) return mostrarToast('No encontrada', 'error');
  const od = (r.ordenDelDia||[]).map(o => typeof o === 'string' ? o : (o.titulo||'')).join('\n');
  mostrarModal('✏️ Editar Reunión', `
    <input type="text" id="reuTituloEdit" class="form-input" value="${r.titulo}" style="margin-bottom:8px">
    <div class="grid-3" style="gap:8px">
      <input type="date" id="reuFechaEdit" class="form-input" value="${(r.fecha||'').slice(0,10)}">
      <input type="time" id="reuHoraEdit" class="form-input" value="${r.hora||''}">
      <input type="time" id="reuHoraFinEdit" class="form-input" value="${r.horaFin||''}">
    </div>
    <input type="text" id="reuLugarEdit" class="form-input" value="${r.lugar||''}" placeholder="Lugar" style="margin-top:8px;margin-bottom:8px">
    <textarea id="reuOrdenEdit" class="form-input" placeholder="Orden del día" style="min-height:80px;margin-bottom:12px">${od}</textarea>
    <button class="btn btn-primary" onclick='guardarEditReunion("${id}")'>💾 Guardar cambios</button>
  `);
}

async function guardarEditReunion(id) {
  const t = document.getElementById('reuTituloEdit')?.value;
  if (!t) return mostrarToast('Introduce un título', 'error');
  try {
    const res = await apiFetch('/junta/api/reuniones/'+id, {
      method:'PUT', body: JSON.stringify({
        titulo: t, fecha: document.getElementById('reuFechaEdit')?.value,
        hora: document.getElementById('reuHoraEdit')?.value, horaFin: document.getElementById('reuHoraFinEdit')?.value,
        lugar: document.getElementById('reuLugarEdit')?.value,
        ordenDelDia: (document.getElementById('reuOrdenEdit')?.value||'').split('\n').filter(Boolean)
      })
    });
    if (res.success) { mostrarToast('✅ Reunión actualizada', 'success'); setTimeout(() => location.reload(), 800); }
    else mostrarToast(res.error||'Error', 'error');
  } catch(e) { mostrarToast('Error de red', 'error'); }
}
</script>