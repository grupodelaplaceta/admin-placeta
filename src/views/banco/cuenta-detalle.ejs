// 7. BAJA DEFINITIVA DE CUENTA (BLP-B-010)
// ═════════════════════════════════════════════════════════════════════════
function mostrarBajaCuenta(id) {
  const origenes = ['Solicitud voluntaria del titular', 'Cierre por inactividad', 'Disolución de empresa',
    'Incumplimiento grave normativa', 'Fraude acreditado', 'Duplicidad administrativa'];
  const motivos = ['Cierre voluntario', 'Cuenta sin saldo', 'Cuenta sin actividad',
    'Cambio de entidad bancaria', 'Reorganización empresarial', 'Resolución sancionadora'];
  const destinos = ['Transferencia a otra cuenta', 'Entrega al titular', 'Distribución entre socios',
    'Compensación tributaria'];
  mostrarModal('🗑️ Baja Definitiva — BLP-B-010', `
    <p style="margin-bottom:8px;font-size:13px;color:#d03131">Cancelación definitiva de la cuenta <strong>${id}</strong></p>
    <p style="font-size:11px;font-weight:600;color:#5c5566;margin-bottom:4px">📋 Origen del procedimiento:</p>
    <select id="bajaOrigen" class="form-input" style="margin-bottom:8px">
      ${origenes.map(o => `<option value="${o}">${o}</option>`).join('')}
    </select>
    <p style="font-size:11px;font-weight:600;color:#5c5566;margin-bottom:4px">📋 Motivo de la baja:</p>
    ${motivoHTML(motivos, ['Cierre voluntario'])}
    <p style="font-size:11px;font-weight:600;color:#5c5566;margin:8px 0 4px">💰 Destino del saldo:</p>
    <select id="bajaDestino" class="form-input" style="margin-bottom:8px">
      ${destinos.map(d => `<option value="${d}">${d}</option>`).join('')}
    </select>
    ${bypassHTML()}
    <button class="btn btn-danger mt-8" onclick="ejecutarBaja('${id}')">🗑️ Dar de baja y generar BLP-B-010</button>
  `);
}

async function ejecutarBaja(id) {
  const motivos = getMotivosSeleccionados();
  const bypass = document.getElementById('chkBypass')?.checked || false;
  if (motivos.length === 0) return mostrarToast('Selecciona al menos un motivo', 'error');
  if (!confirm('🗑️ ¿Cancelar DEFINITIVAMENTE la cuenta ' + id + '?\n\nEsta acción es irreversible.\nMotivo: ' + motivos.join(', ') + (bypass ? '\n\n⚠️ BYPASS activo' : ''))) return;
  try {
    await apiFetch('/banco/api/cuentas/modificar', {
      method:'POST', body: JSON.stringify({
        accountId:id, baja: true, motivos,
        origen: document.getElementById('bajaOrigen')?.value,
        destinoSaldo: document.getElementById('bajaDestino')?.value,
        bypass
      })
    });
    mostrarToast('🗑️ Cuenta cancelada — BLP-B-010 generado' + (bypass ? ' [BY-PASS]' : ''), 'warning');
    setTimeout(() => location.reload(), 1000);
  } catch { mostrarToast('⚠️ Error', 'error'); }
}
